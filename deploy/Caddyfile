# Caddy — reverse proxy con HTTPS automático (Let's Encrypt).
# Instalar en el server como /etc/caddy/Caddyfile y recargar: sudo systemctl reload caddy
#
# Requisito: los registros DNS A/AAAA de btop-rentals.com y www ya deben apuntar
# a la IP del server (Caddy valida el dominio para emitir el certificado).

# www → apex (301)
www.btop-rentals.com {
	redir https://btop-rentals.com{uri} permanent
}

btop-rentals.com {
	encode gzip zstd

	# Webhook de pagos bajo el dominio propio (oculta el proveedor del backend).
	# Reenvía el cuerpo tal cual (la verificación de firma del pago necesita el raw body).
	handle /api/stripe/webhook {
		rewrite * /functions/v1/stripe-webhook
		reverse_proxy https://onpvhedeinpsggdanylg.supabase.co {
			header_up Host onpvhedeinpsggdanylg.supabase.co
		}
	}

	# App
	handle {
		reverse_proxy localhost:3000
	}

	# Cabeceras de seguridad básicas
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options SAMEORIGIN
		Referrer-Policy strict-origin-when-cross-origin
	}
}
